# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=polymarket_tracker
POSTGRES_USER=tracker
POSTGRES_PASSWORD=dev_password

# Constructed database URL (for application use)
DATABASE_URL=postgresql://tracker:dev_password@localhost:5432/polymarket_tracker

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Optional: Development tool ports
ADMINER_PORT=8080
REDIS_INSIGHT_PORT=5540

# Polygon RPC Configuration
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_FALLBACK_RPC_URL=https://polygon-bor.publicnode.com

# Ankr Advanced API (optional; needed only for wallet first-tx / age lookup).
# Standard Polygon JSON-RPC cannot answer "first transaction by address"
# cheaply, so without an Ankr key WalletProfile.age_hours will stay None
# and the freshness heuristic falls back to nonce alone.
# Get a key at https://www.ankr.com/rpc/advanced-api/
ANKR_API_KEY=
# ANKR_BLOCKCHAIN=polygon
# ANKR_ENDPOINT=https://rpc.ankr.com/multichain

# Polymarket API Configuration
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Alert Webhooks (optional)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
